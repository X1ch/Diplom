<Page x:Class="Uchet_Oborudovania.Pages.SpisaniePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Uchet_Oborudovania.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SpisaniePage" Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="SpisanieDG" HorizontalContentAlignment="Stretch" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ID_Spisanie}"/>
                <DataGridTextColumn Header="Серийный номер" Binding="{Binding Seriyn_Num}"/>
                <DataGridTextColumn Header="Дата списания" Binding="{Binding Date_Spisania, StringFormat=dd.MM.yyyy}"/>
                <DataGridTextColumn Header="Причина списания" Binding="{Binding Prichina_Spisania}"/>
                <DataGridTextColumn Header="Сотрудник списавший" Binding="{Binding Sotrudnik_Spisavshi_FIO}"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Orientation="Horizontal" Grid.Row="1">
            <Button x:Name="AddBtn" Content="Добавить" Margin="5" Height="30" Width="150" Click="AddBtn_Click"/>
            <ComboBox x:Name="cbEmployeeFilter" Margin="5" Height="30" Width="150" DisplayMemberPath="Fio" SelectionChanged="cbEmployeeFilter_SelectionChanged" />
        </StackPanel>
    </Grid>
</Page>
