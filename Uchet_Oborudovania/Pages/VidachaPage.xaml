<Page x:Class="Uchet_Oborudovania.Pages.VidachiPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Uchet_Oborudovania.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="VidachiPage" Loaded="Page_Loaded_1">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="VidachiDG" HorizontalContentAlignment="Stretch" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ID_Vidachi}"/>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding Users.Fio}"/>
                <DataGridTextColumn Header="Серийный номер" Binding="{Binding Oborudovanie.Seriyn_Num}"/>
                <DataGridTextColumn Header="Дата выдачи" Binding="{Binding Date_Vidachi, StringFormat=dd.MM.yyyy}"/>
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Tag="{Binding}" Content="Вернуть" Margin="5" Height="30" Width="150" Click="Button_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Orientation="Horizontal" Grid.Row="1">
            <Button x:Name="AddBtn" Content="Выдать" Margin="5" Height="30" Width="150" Click="AddBtn_Click"/>
            <ComboBox x:Name="SortCB" Width="150" Height="25"
                      SelectionChanged="SortCB_SelectionChanged">
                <ComboBoxItem Content="По умолчанию" Tag="Default"/>
                <ComboBoxItem Content="Дата ↑" Tag="QuantityAsc"/> <!-- от старой к новому -->
                <ComboBoxItem Content="Дата ↓" Tag="QuantityDesc"/>
            </ComboBox>
        </StackPanel>
    </Grid>
</Page>
