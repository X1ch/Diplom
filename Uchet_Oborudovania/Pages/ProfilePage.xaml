<Page x:Class="Uchet_Oborudovania.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage"
      Background="#F5F5F5">

    <Grid Margin="20">
        <Border Background="White" 
                CornerRadius="10" 
                Padding="25"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="500">
            <StackPanel>
                <!-- Заголовок -->
                <TextBlock Text="👤 Профиль пользователя" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="#2a3f54"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Аватар -->
                <Border Background="#2a3f54" 
                        CornerRadius="60" 
                        Width="120" 
                        Height="120" 
                        HorizontalAlignment="Center"
                        Margin="0,0,0,25">
                    <TextBlock Text="👤" 
                               FontSize="55" 
                               Foreground="White" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Информация о пользователе -->
                <Border Background="#F9F9F9" 
                        CornerRadius="8" 
                        Padding="15"
                        Margin="0,0,0,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ФИО -->
                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                   Text="ФИО:" 
                                   FontWeight="Bold" 
                                   Foreground="#555"
                                   Margin="0,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" 
                                   x:Name="TxtFIO" 
                                   Foreground="#333"
                                   Margin="0,8"/>

                        <!-- Логин -->
                        <TextBlock Grid.Row="1" Grid.Column="0" 
                                   Text="Логин:" 
                                   FontWeight="Bold" 
                                   Foreground="#555"
                                   Margin="0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" 
                                   x:Name="TxtLogin" 
                                   Foreground="#333"
                                   Margin="0,8"/>

                        <!-- Роль -->
                        <TextBlock Grid.Row="2" Grid.Column="0" 
                                   Text="Роль:" 
                                   FontWeight="Bold" 
                                   Foreground="#555"
                                   Margin="0,8"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" 
                                   x:Name="TxtRole" 
                                   Foreground="#333"
                                   Margin="0,8"/>

                        <!-- Должность -->
                        <TextBlock Grid.Row="3" Grid.Column="0" 
                                   Text="Должность:" 
                                   FontWeight="Bold" 
                                   Foreground="#555"
                                   Margin="0,8"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" 
                                   x:Name="TxtDolzhnost" 
                                   Foreground="#333"
                                   Margin="0,8"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Page>