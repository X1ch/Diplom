<Page x:Class="Uchet_Oborudovania.Pages.OborudovaniePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Uchet_Oborudovania.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="OborudovaniePage"
      Loaded="Page_Loaded">

    <Grid>
        <Grid >
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" >
                <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="searchTB" TextWrapping="Wrap" Margin="5" Height="30" Width="150" TextChanged="searchTB_TextChanged" />
                <TextBlock Text="Фильтровать:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="StatusCB" Width="150" Height="25"/>
                <Button Content="Фильтровать" Margin="5" Height="30" Width="100" Click="Button_Click_1"/>
            </StackPanel>
            <DataGrid Grid.Row="1" x:Name="OborudovanieDG" HorizontalContentAlignment="Stretch" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ID_PC}"/>
                    <DataGridTextColumn Header="Серийный номер" Binding="{Binding Seriyn_Num}"/>
                    <DataGridTextColumn Header="Категория" Binding="{Binding Category_Oborudovania.NameCategory}"/>
                    <DataGridTextColumn Header="Модель" Binding="{Binding Model}"/>
                    <DataGridTextColumn Header="Дата покупки" Binding="{Binding Date_Buy, StringFormat=dd.MM.yyyy}"/>
                    <DataGridTextColumn Header="Гарантия" Binding="{Binding Garantia}"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status_Oborudovania.Name_Status}"/>
                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Изменить" Margin="5" Height="30" Width="150" Click="Button_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Orientation="Horizontal" Grid.Row="2">
                <Button x:Name="AddBtn" Content="Добавить" Margin="5" Height="30" Width="150" Click="AddBtn_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
