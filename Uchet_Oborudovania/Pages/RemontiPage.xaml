<Page x:Class="Uchet_Oborudovania.Pages.RemontiPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Uchet_Oborudovania.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RemontiPage"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="RemontiDG" HorizontalContentAlignment="Stretch" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ID_Remont}"/>
                <DataGridTextColumn Header="Серийный номер" Binding="{Binding Oborudovanie.Seriyn_Num}"/>
                <DataGridTextColumn Header="Компания ремонта" Binding="{Binding Company_Remont}"/>
                <DataGridTextColumn Header="Причина ремонта" Binding="{Binding Prichina_Remonta}"/>
                <DataGridTextColumn Header="Дата ремонта" Binding="{Binding Date_Remonta, StringFormat=dd.MM.yyyy}"/>
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Изменить" Margin="5" Height="30" Width="150" Click="Button_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status_Remonta}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Orientation="Horizontal" Grid.Row="1">
            <Button x:Name="AddBtn" Content="Добавить" Margin="5" Height="30" Width="150" Click="AddBtn_Click"/>
            <Button x:Name="DelBtn" Content="Удалить" Margin="5" Height="30" Width="150" Click="DelBtn_Click"/>
            <ComboBox x:Name="combobox1" Margin="5" Height="30" Width="150"/>
            <Button x:Name="FilterBtn" Content="Фильтровать" Margin="5" Height="30" Width="150" Click="FilterBtn_Click"/>
        </StackPanel>
    </Grid>
</Page>
