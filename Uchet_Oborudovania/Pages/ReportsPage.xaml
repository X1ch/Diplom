<Page x:Class="Uchet_Oborudovania.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Uchet_Oborudovania.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ReportsPage">

    <Grid>
        <StackPanel Orientation="Vertical" >
            <Button x:Name="RepObBtn" Content="Отчет о выданном оборудовании" Margin="5" Height="30"  Click="RepoBtn_Click"/>
            <Button x:Name="RepRemBtn" Content="Отчет о ремонте оборудования" Margin="5" Height="30" Click="RepRemBtn_Click"/>
            <Button x:Name="RepSpisBtn" Content="Отчет о списанном оборудовании" Margin="5" Height="30" Click="RepSpisBtn_Click"/>
            <Button x:Name="RepOborudBtn" Content="Отчет об оборудовании" Margin="5" Height="30" Click="RepOborudBtn_Click"/>
        </StackPanel>
    </Grid>
</Page>
