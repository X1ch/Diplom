<Page x:Class="Uchet_Oborudovania.Pages.SkladPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Uchet_Oborudovania.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SkladPage" Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="SkladDG" HorizontalContentAlignment="Stretch" AutoGenerateColumns="False" IsReadOnly="True" Grid.Row="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ID_PC}"/>
                <DataGridTextColumn Header="Серийный номер" Binding="{Binding Seriyn_Num}"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category_Oborudovania.NameCategory}"/>
                <DataGridTextColumn Header="Модель" Binding="{Binding Model}"/>
                <DataGridTextColumn Header="Дата покупки" Binding="{Binding Date_Buy, StringFormat=dd.MM.yyyy}"/>
                <DataGridTextColumn Header="Гарантия" Binding="{Binding Garantia}"/>
                
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
