<Page x:Class="Uchet_Oborudovania.Pages.AddSpisanie"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Uchet_Oborudovania.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddSpisanie">

    <Grid>
        <Border Background="White" CornerRadius="10" Padding="25" 
                Width="400" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" >
                <TextBlock x:Name="TitleText" Text="Списание оборудования" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#2a3f54"/>
                <TextBlock Text="Серийный номер" FontWeight="SemiBold" Margin="0,5"/>
                <ComboBox x:Name="SpisanieSerNumCB" SelectedItem="{Binding Oborudovanie}" DisplayMemberPath="Seriyn_Num" Margin="0,5" Height="35" Padding="10"/>
                <TextBlock Text="Причина списания" FontWeight="SemiBold" Margin="0,5"/>
                <TextBox x:Name="PrichinaTB" Text="{Binding Prichina_Spisania}"  Margin="0,5" Height="35" Padding="10"/>
                <TextBlock Text="Дата списания" FontWeight="SemiBold" Margin="0,5"/>
                <DatePicker SelectedDate="{Binding Date_Spisania}"  Margin="0,5" Height="35" Padding="10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button x:Name="SaveBtn" Content="Сохранить" Click="SaveBtn_Click" Width="120" Height="35" Margin="0,0,10,0" Background="#4CAF50" Foreground="White" Cursor="Hand"/>
                    <Button x:Name="BackBtn" Content="Отмена" Click="BackBtn_Click" Width="120" Height="35" Background="#666" Foreground="White" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
