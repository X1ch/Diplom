<Window x:Class="Uchet_Oborudovania.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Uchet_Oborudovania"
        mc:Ignorable="d"
        Title="Учет оборудования" 
        Height="700" Width="1200"
        Loaded="Window_Loaded"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Стиль для кнопок меню -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                Padding="15,0">
                            <ContentPresenter HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3a5a7a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопки профиля -->
        <Style x:Key="ProfileButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3a5a7a"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="55"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                Padding="15,5"
                                CornerRadius="5">
                            <StackPanel>
                                <TextBlock x:Name="TxtFIO" 
                                           Text="{Binding FIO, RelativeSource={RelativeSource TemplatedParent}}" 
                                           FontWeight="SemiBold"
                                           FontSize="14"/>
                                <TextBlock x:Name="TxtRole" 
                                           Text="{Binding Role, RelativeSource={RelativeSource TemplatedParent}}" 
                                           FontSize="11"
                                           Opacity="0.8"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4a6a8a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- БОКОВОЕ МЕНЮ -->
        <Border Grid.Column="0" Background="#2a3f54">
            <StackPanel>
                <!-- Логотип -->
                <Border Height="100" Margin="0,20,0,10">
                    <Image x:Name="LogoImage" 
                           Source="logo.png" 
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                </Border>



                <!-- Кнопки меню -->
                <Button x:Name="BtnEmployees" 
                        Content="👥  Сотрудники" 
                        Style="{StaticResource MenuButtonStyle}"
                        Click="BtnEmployees_Click"/>

                <Button x:Name="BtnEquipment" 
                        Content="🖥️  Оборудование" 
                        Style="{StaticResource MenuButtonStyle}"
                        Click="BtnEquipment_Click"/>

                <Button x:Name="BtnRepairs" 
                        Content="🔧  Ремонт" 
                        Style="{StaticResource MenuButtonStyle}"
                        Click="BtnRepairs_Click"/>

                <Button x:Name="BtnIssues" 
                        Content="📤  Выдача" 
                        Style="{StaticResource MenuButtonStyle}"
                        Click="BtnIssues_Click"/>

                <Button x:Name="BtnSpisanie" 
                        Content="🗑️ Списание" 
                        Style="{StaticResource MenuButtonStyle}"
                        Click="BtnSpisanie_Click"/>

                <Button x:Name="BtnSklad" 
                        Content="📦  Склад" 
                        Style="{StaticResource MenuButtonStyle}"
                        Click="BtnSklad_Click"/>

                <Button x:Name="BtnReports" 
                        Content="📊  Отчеты" 
                        Style="{StaticResource MenuButtonStyle}"
                        Click="BtnReports_Click"/>
                <Separator Background="#3a5a7a" Margin="15,10" Height="1"/>
                <Button x:Name="BtnLogout" 
                        Content="🔄  Сменить пользователя" 
                        Style="{StaticResource MenuButtonStyle}"
                        Click="BtnLogout_Click"
                        />
                <Button x:Name="BtnExit" 
                        Content="🚪  Выход" 
                        Style="{StaticResource MenuButtonStyle}"
                        Click="BtnExit_Click"
                        />
            </StackPanel>
        </Border>

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Верхняя панель с информацией о пользователе -->
            <Border Grid.Row="0" Background="#f5f5f5" BorderBrush="#e0e0e0" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Заголовок страницы (будет динамическим) -->
                    <TextBlock x:Name="PageTitle" 
                               Text="Ремонт" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="#2a3f54"
                               VerticalAlignment="Center"/>

                    <!-- Карточка пользователя (кликабельная) -->
                    <Button x:Name="UserCardBtn" 
                            Grid.Column="1"
                            Click="BtnProfile_Click"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0">
                        <Border Background="#e8f0fe" 
                                CornerRadius="8" 
                                Padding="12,5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👤 " FontSize="18" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock x:Name="TxtUserFIO" 
                                               Text="" 
                                               FontSize="14" 
                                               FontWeight="SemiBold" 
                                               Foreground="#2a3f54"/>
                                    <TextBlock x:Name="TxtUserRole" 
                                               Text="" 
                                               FontSize="11" 
                                               Foreground="#666"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Button>
                </Grid>
            </Border>

            <!-- Frame для страниц -->
            <Frame x:Name="MainContentFrame" 
                   Grid.Row="1" 
                   NavigationUIVisibility="Hidden" />
        </Grid>
    </Grid>
</Window>